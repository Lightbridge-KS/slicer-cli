# Integration-test fixture for Orthanc-backed DICOMweb tests.
#
# Copy this file to `tests/integration/.env` (gitignored) and fill in the
# UIDs / patient-name substring of a real study you have loaded into your
# local Orthanc instance. Real DICOM UIDs are considered PHI under HIPAA —
# keep them out of git.
#
# If any of these vars is unset, `requires_orthanc`-marked tests skip cleanly.

SLCLI_TEST_ORTHANC_URL=http://localhost:8042

# A real StudyInstanceUID present in your Orthanc DICOMweb store.
SLCLI_TEST_STUDY_UID=

# A SeriesInstanceUID belonging to that study.
SLCLI_TEST_SERIES_UID=

# A SOPInstanceUID belonging to that series.
SLCLI_TEST_SOP_UID=

# A substring expected to appear in the study's PatientName (e.g. surname).
# Used only for client-side filtering assertions, never sent over the wire.
SLCLI_TEST_PATIENT_NAME_SUBSTR=
